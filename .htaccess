# .htaccess for Apache-style URL rewriting
# Also works as documentation for URL structure

RewriteEngine On
RewriteBase /

# Don't rewrite existing files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Redirect /app/* to index.php?path=app/*
RewriteRule ^app/(.*)$ index.php?path=app/$1 [QSA,L]

# Redirect root to dashboard
RewriteRule ^$ index.php?path=dashboard [QSA,L]
