# CyborX .htaccess for Apache-style URL rewriting
# For use with PHP built-in server that supports it

RewriteEngine On

# Don't rewrite for existing files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Send all other requests to index.php
RewriteRule ^(.*)$ index.php?path=$1 [QSA,L]
