# CyborX Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_DEBUG=false
APP_HOST=cyborx.net

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=cyberx_official_bot
TELEGRAM_ADMIN_USERNAME=eviltesting
TELEGRAM_ADMIN_ID=your_admin_id_here

# Telegram Group/Channel Configuration
TELEGRAM_ANNOUNCE_CHAT_ID=-1003278376068
TELEGRAM_GROUP_LINK=https://t.me/+3K_LpkllbkA2ZjFl

# Allowlist (optional - comma separated Telegram user IDs)
TELEGRAM_REQUIRE_ALLOWLIST=false
TELEGRAM_ALLOWED_IDS=

# Database Configuration (Railway will provide these)
DB_DSN=mysql:host=127.0.0.1;dbname=railway;charset=utf8mb4
DB_USER=root
DB_PASS=

# Session Configuration
SESSION_NAME=CYBORXSESSID
SESSION_COOKIE_DOMAIN=.databasemanaging.com
SESSION_COOKIE_LIFETIME=7200
SESSION_GC_MAXLIFETIME=7200
SESSION_SAMESITE=Lax
SESSION_IDLE_MAX=7200

# Optional: IPQualityScore for proxy fraud detection
IPQS_KEY=
